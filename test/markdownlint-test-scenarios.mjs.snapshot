t-configure-file {\\n  \\"link-fragments\\": false,\\n  \\"link-image-style\\": {\\n    \\"autolink\\": false,\\n    \\"inline\\": false,\\n    \\"full\\": false,\\n    \\"shortcut\\": false\\n  }\\n} -->\\n"
