39}\\n\\n[ref][] {MD039}\\n\\n[ref]: https://example.com\\n\\nNot a link, just [ text in ] brackets\\n\\nImages are ![ not links ](image.jpg)\\n\\n<!-- markdownlint-configure-file {\\n  \\"descriptive-link-text\\": false\\n} -->"
}
`;

