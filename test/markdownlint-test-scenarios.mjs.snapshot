MPLE\\",\\n      \\"HTTPS\\",\\n      \\"FILE\\",\\n      \\"COM\\"\\n    ]\\n  },\\n  \\"line-length\\": false,\\n  \\"no-bare-urls\\": false,\\n  \\"code-block-style\\": false\\n} -->\\n"
}
`;

